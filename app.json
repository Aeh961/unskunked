{
  "expo": {
    "name": "Unskunked",
    "slug": "unskunked",
    "version": "0.1.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "scheme": "unskunked",
    "userInterfaceStyle": "automatic",
    "splash": {
      "backgroundColor": "#f3f0e8"
    },
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#f3f0e8"
      }
    },
    "plugins": ["expo-router"],
    "experiments": {
      "typedRoutes": true
    }
  }
}
