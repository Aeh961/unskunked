{
  "expo": {
    "name": "Unskunked",
    "slug": "unskunked",
    "version": "0.1.0",
    "orientation": "portrait",
    "scheme": "unskunked",
    "icon": "./assets/unskunked-icon.svg",
    "userInterfaceStyle": "automatic",
    "jsEngine": "jsc",
    "splash": {
      "image": "./assets/unskunked-splash.svg",
      "resizeMode": "contain",
      "backgroundColor": "#f4f1e8"
    },
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSLocationWhenInUseUsageDescription": "Unskunked uses your location to sort nearby fishing spots. You can use manual location fallback instead."
      }
    },
    "android": {
      "permissions": [
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION"
      ],
      "adaptiveIcon": {
        "foregroundImage": "./assets/unskunked-icon.svg",
        "backgroundColor": "#123B30"
      }
    },
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
